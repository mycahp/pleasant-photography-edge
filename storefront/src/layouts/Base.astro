---
interface Props {
	title?: string;
	description?: string;
	activePage?: 'home' | 'about' | 'contact';
}

const {
	title = 'mycah pleasant photography',
	description = 'Beautiful photography portfolio',
	activePage = 'home',
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fragment+Mono:ital@0;1&display=swap" rel="stylesheet">
		<title>{title}</title>
		<meta name="description" content={description} />
		<style>
			:root {
				--font: 'Fragment Mono', monospace;
			}
			* {
				font-family: var(--font);
			}

			body::before {
				content: '';
				position: fixed;
				inset: 0;
				z-index: 100;
				pointer-events: none;
				opacity: 0.035;
				background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
				background-size: 200px 200px;
				background-repeat: repeat;
			}

			.nav-link {
				position: relative;
				display: inline-block;
			}
			.nav-link::after {
				content: '';
				position: absolute;
				bottom: -2px;
				left: 0;
				width: 0;
				height: 1px;
				background: #3b82f6;
				transition: width 0.25s ease;
			}
			.nav-link:hover::after,
			.nav-link.active::after {
				width: 100%;
			}

			/* Hide brand in nav on mobile — links don't have room */
			@media (max-width: 767px) {
				#nav-brand {
					display: none !important;
				}
			}

			#cart-drawer {
				transition: transform 0.25s ease;
			}
			#cart-drawer.open {
				transform: translateX(0);
			}
		</style>
	</head>
	<body class="bg-zinc-950 text-zinc-50">

		<nav id="top-nav" data-page={activePage} class="fixed top-0 inset-x-0 z-50 bg-zinc-900 border-t-2 border-blue-500 backdrop-blur-sm" style="transition: background-color 0.2s ease;">
			<div class="relative flex items-center justify-end px-6 py-3">
				<a href="/" class="absolute left-6 text-sm opacity-0 transition-opacity duration-200 pointer-events-none whitespace-nowrap" id="nav-brand">mycah pleasant <span class="text-blue-500">photography</span></a>
				<div style="display: flex; align-items: center; gap: 1.25rem;">
					<a href="/" class={`nav-link text-sm ${activePage === 'home' ? 'active' : ''}`} style="white-space: nowrap;">home</a>
					<a href="/about" class={`nav-link text-sm ${activePage === 'about' ? 'active' : ''}`} style="white-space: nowrap;">about</a>
					<a href="/contact" class={`nav-link text-sm ${activePage === 'contact' ? 'active' : ''}`} style="white-space: nowrap;">contact<span class="hidden md:inline"> and bookings</span></a>
					<button id="cart-btn" class="nav-link text-sm relative" style="white-space: nowrap;" aria-label="open cart">
						cart
						<span id="cart-badge" class="hidden absolute -top-2 -right-3 bg-blue-500 text-white text-[10px] w-4 h-4 rounded-full items-center justify-center leading-none">0</span>
					</button>
				</div>
			</div>
		</nav>

		<slot />

		<footer class="border-t border-zinc-800 bg-zinc-900">
			<div class="px-8 py-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-zinc-500">
				<span>© {new Date().getFullYear()} mycah pleasant <span class="text-blue-500">photography</span>. all rights reserved.</span>
				<div class="flex items-center gap-6">
					<a href="/about" class="hover:text-zinc-300 transition-colors">about</a>
					<a href="/contact" class="hover:text-zinc-300 transition-colors">contact and bookings</a>
				</div>
			</div>
		</footer>

		<!-- Cart backdrop -->
		<div id="cart-backdrop" class="fixed inset-0 z-[290] hidden" style="background: rgba(9,9,11,0.5);" aria-hidden="true"></div>

		<!-- Cart drawer -->
		<div id="cart-drawer" class="fixed inset-y-0 right-0 z-[300] w-80 max-w-[90vw] bg-zinc-900 border-l border-zinc-800 translate-x-full flex flex-col">
			<div class="px-5 py-4 border-b border-zinc-800 flex items-center justify-between shrink-0">
				<h2 class="text-sm tracking-wide">cart</h2>
				<button id="cart-close" class="text-zinc-500 hover:text-white text-xl leading-none transition-colors">×</button>
			</div>
			<div id="cart-items" class="flex-1 overflow-y-auto hidden"></div>
			<div id="cart-empty" class="flex-1 flex items-center justify-center">
				<p class="text-zinc-500 text-sm">your cart is empty</p>
			</div>
			<div id="cart-footer" class="p-5 border-t border-zinc-800 shrink-0 hidden">
				<div class="flex justify-between items-baseline mb-4">
					<span class="text-xs text-zinc-400">total</span>
					<span id="cart-total" class="text-blue-500 text-sm"></span>
				</div>
				<button id="checkout-btn" class="w-full bg-blue-500 hover:bg-blue-400 text-white py-2.5 text-sm transition-colors tracking-wide disabled:opacity-50 disabled:cursor-not-allowed">checkout</button>
			</div>
		</div>

		<!-- Checkout overlay -->
		<div id="checkout-overlay" class="fixed inset-0 z-[400] bg-zinc-950 overflow-y-auto hidden flex-col">
			<div class="max-w-xl mx-auto py-10 px-5 w-full">
				<div class="flex items-center justify-between mb-8">
					<span class="text-sm text-zinc-400">checkout</span>
					<button id="checkout-close" class="text-zinc-500 hover:text-white text-xl leading-none transition-colors">×</button>
				</div>
				<div id="checkout-element"></div>
			</div>
		</div>

		<script>
			import { api } from '../lib/api';
			import {
				getCart,
				removeFromCart,
				setQuantity,
				cartTotal,
				cartCount,
			} from '../lib/cart';

			const STRIPE_KEY = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY as string;

			function formatPrice(cents: number): string {
				return `$${(cents / 100).toFixed(2)}`;
			}

			// ---- Nav brand ----

			const topNav = document.getElementById('top-nav')!;
			const navBrand = document.getElementById('nav-brand')!;
			const isHome = topNav.dataset.page === 'home';

			function setNavScrolled(scrolled: boolean): void {
				navBrand.style.opacity = scrolled ? '1' : '0';
				navBrand.style.pointerEvents = scrolled ? 'auto' : 'none';
				topNav.style.backgroundColor = scrolled ? 'rgba(24, 24, 27, 0.75)' : '';
			}

			if (!isHome) {
				navBrand.style.opacity = '1';
				navBrand.style.pointerEvents = 'auto';
				topNav.style.backgroundColor = '#18181b';
			} else {
				// On homepage, show when the header cell scrolls out of view
				const headerCell = document.getElementById('header-cell');
				if (headerCell) {
					new IntersectionObserver(([entry]) => {
						setNavScrolled(!entry.isIntersecting);
					}, { threshold: 0 }).observe(headerCell);
				}
			}

			// ---- Cart badge ----

			const cartBadge = document.getElementById('cart-badge')!;

			function updateCartBadge(): void {
				const count = cartCount(getCart());
				if (count > 0) {
					cartBadge.textContent = String(count > 99 ? '99+' : count);
					cartBadge.classList.remove('hidden');
					cartBadge.classList.add('flex');
				} else {
					cartBadge.classList.add('hidden');
					cartBadge.classList.remove('flex');
				}
			}

			updateCartBadge();
			window.addEventListener('cart:updated', updateCartBadge);

			// ---- Cart drawer ----

			const cartBtn = document.getElementById('cart-btn')!;
			const cartDrawer = document.getElementById('cart-drawer')!;
			const cartBackdrop = document.getElementById('cart-backdrop')!;
			const cartClose = document.getElementById('cart-close')!;
			const cartItemsEl = document.getElementById('cart-items')!;
			const cartEmptyEl = document.getElementById('cart-empty')!;
			const cartFooterEl = document.getElementById('cart-footer')!;
			const cartTotalEl = document.getElementById('cart-total')!;
			const checkoutBtn = document.getElementById('checkout-btn') as HTMLButtonElement;

			function openCartDrawer(): void {
				renderCartDrawer();
				cartDrawer.classList.add('open');
				cartBackdrop.classList.remove('hidden');
				document.body.style.overflow = 'hidden';
			}

			function closeCartDrawer(): void {
				cartDrawer.classList.remove('open');
				cartBackdrop.classList.add('hidden');
				document.body.style.overflow = '';
			}

			function renderCartDrawer(): void {
				const cart = getCart();
				cartItemsEl.innerHTML = '';

				if (cart.length === 0) {
					cartItemsEl.classList.add('hidden');
					cartEmptyEl.classList.remove('hidden');
					cartFooterEl.classList.add('hidden');
				} else {
					cartItemsEl.classList.remove('hidden');
					cartEmptyEl.classList.add('hidden');
					cartFooterEl.classList.remove('hidden');

					for (const item of cart) {
						const el = document.createElement('div');
						el.className = 'px-5 py-3 border-b border-zinc-800';
						el.innerHTML = `
							<div class="flex items-start justify-between gap-2 mb-2">
								<div class="min-w-0">
									<p class="text-xs truncate">${item.productName}</p>
									<p class="text-xs text-zinc-500">${item.printSize}</p>
								</div>
								<button class="remove-btn text-zinc-600 hover:text-red-400 text-lg leading-none transition-colors shrink-0" data-price-id="${item.priceId}" aria-label="remove">×</button>
							</div>
							<div class="flex items-center justify-between">
								<div class="flex items-center gap-2">
									<button class="qty-dec text-zinc-500 hover:text-white w-6 h-6 flex items-center justify-center border border-zinc-700 hover:border-zinc-500 transition-colors text-xs" data-price-id="${item.priceId}" aria-label="decrease quantity">−</button>
									<span class="text-xs w-5 text-center">${item.quantity}</span>
									<button class="qty-inc text-zinc-500 hover:text-white w-6 h-6 flex items-center justify-center border border-zinc-700 hover:border-zinc-500 transition-colors text-xs" data-price-id="${item.priceId}" aria-label="increase quantity">+</button>
								</div>
								<span class="text-xs text-blue-500">${formatPrice(item.unitAmount * item.quantity)}</span>
							</div>
						`;
						cartItemsEl.appendChild(el);
					}

					cartTotalEl.textContent = formatPrice(cartTotal(cart));
				}
			}

			cartItemsEl.addEventListener('click', (e) => {
				const target = e.target as HTMLElement;
				const priceId = target.dataset.priceId;
				if (!priceId) return;

				if (target.classList.contains('remove-btn')) {
					removeFromCart(priceId);
					renderCartDrawer();
				} else if (target.classList.contains('qty-dec')) {
					const item = getCart().find((i) => i.priceId === priceId);
					if (item) { setQuantity(priceId, item.quantity - 1); renderCartDrawer(); }
				} else if (target.classList.contains('qty-inc')) {
					const item = getCart().find((i) => i.priceId === priceId);
					if (item) { setQuantity(priceId, item.quantity + 1); renderCartDrawer(); }
				}
			});

			cartBtn.addEventListener('click', openCartDrawer);
			cartClose.addEventListener('click', closeCartDrawer);
			cartBackdrop.addEventListener('click', closeCartDrawer);

			// Re-render drawer on cart updates (e.g. add from product modal)
			window.addEventListener('cart:updated', () => {
				if (cartDrawer.classList.contains('open')) renderCartDrawer();
			});

			// ---- Checkout ----

			const checkoutOverlay = document.getElementById('checkout-overlay')!;
			const checkoutClose = document.getElementById('checkout-close')!;
			const checkoutElement = document.getElementById('checkout-element')!;

			let stripeCheckout: { mount: (el: HTMLElement) => void; destroy: () => void } | null = null;

			async function initiateCheckout(): Promise<void> {
				const cart = getCart();
				if (cart.length === 0) return;

				if (!STRIPE_KEY) {
					alert('Stripe is not configured. Add PUBLIC_STRIPE_PUBLISHABLE_KEY to your .env file.');
					return;
				}

				checkoutBtn.textContent = 'loading...';
				checkoutBtn.disabled = true;

				try {
					const returnUrl = `${window.location.origin}/return?session_id={CHECKOUT_SESSION_ID}`;

					const res = await fetch(api.checkout, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							items: cart.map((i) => ({ priceId: i.priceId, quantity: i.quantity })),
							returnUrl,
						}),
					});

					if (!res.ok) {
						let message = `API error ${res.status}`;
						try {
							const err = await res.json() as { error: string };
							message = err.error ?? message;
						} catch { /* ignore parse error */ }
						throw new Error(message);
					}

					const { clientSecret } = await res.json() as { clientSecret: string };

					const { loadStripe } = await import('@stripe/stripe-js');
					const stripe = await loadStripe(STRIPE_KEY);
					if (!stripe) throw new Error('Failed to load Stripe.js');

					checkoutElement.innerHTML = '';
					stripeCheckout = await stripe.initEmbeddedCheckout({ clientSecret });
					stripeCheckout.mount(checkoutElement);

					closeCartDrawer();
					checkoutOverlay.classList.remove('hidden');
					checkoutOverlay.classList.add('flex');
					document.body.style.overflow = 'hidden';
				} catch (err) {
					const message = err instanceof Error ? err.message : 'Unknown error';
					console.error('Checkout error:', err);
					alert(`Checkout failed: ${message}`);
				} finally {
					checkoutBtn.textContent = 'checkout';
					checkoutBtn.disabled = false;
				}
			}

			function closeCheckout(): void {
				checkoutOverlay.classList.add('hidden');
				checkoutOverlay.classList.remove('flex');
				document.body.style.overflow = '';
				if (stripeCheckout) {
					stripeCheckout.destroy();
					stripeCheckout = null;
				}
				checkoutElement.innerHTML = '';
			}

			checkoutBtn.addEventListener('click', initiateCheckout);
			checkoutClose.addEventListener('click', closeCheckout);

			document.addEventListener('keydown', (e) => {
				if (e.key !== 'Escape') return;
				if (checkoutOverlay.classList.contains('flex')) {
					closeCheckout();
				} else if (cartDrawer.classList.contains('open')) {
					closeCartDrawer();
				}
			});
		</script>

	</body>
</html>
